# ------------------------------------------------------------
# Backend: Database
# ------------------------------------------------------------
# Postgres-Verbindung (Supabase): postgresql+psycopg://USER:PASS@HOST:PORT/DB
# Fuer den aktuellen Multi-User/Auth-Betrieb ist Postgres erforderlich.
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:PORT/DB

# ------------------------------------------------------------
# Backend: Supabase
# ------------------------------------------------------------
# Projekt-URL, Publishable Key und Secret Key aus Supabase.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Pflicht im Supabase-Betrieb: verhindert Selbstloeschung des Haupt-Admins.
PRIMARY_ADMIN_USER_ID=

# ------------------------------------------------------------
# Backend: CORS
# ------------------------------------------------------------
# Erlaubte Origins (kommagetrennt), z. B.:
# Dev:  http://localhost:3000,http://127.0.0.1:3000
# Prod: https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Regex fuer Preview-Domains (z. B. Vercel).
CORS_ALLOWED_ORIGIN_REGEX=

# ------------------------------------------------------------
# Backend: AI
# ------------------------------------------------------------
# OpenAI-kompatibler Anbieter (Default: OpenRouter).
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=google/gemini-2.0-flash-001

# ------------------------------------------------------------
# Backend: Telegram
# ------------------------------------------------------------
# Globaler Bot-Token; Chat-ID wird pro User in den UserSettings gespeichert.
TELEGRAM_BOT_TOKEN=

# ------------------------------------------------------------
# Optional: Remote MCP-Server (mcp-server/, liest diese Root-.env mit)
# ------------------------------------------------------------
# Zwei verschiedene URLs — beide nur noetig, wenn du vom Default abweichst:
#
# SCHNAPPSTER_API_BASE_URL — wohin der MCP-Server die Schnappster-FastAPI schickt
#   (HTTP-Client fuer Tools: /api/ads/, /api/users/me/, …).
#   Default: http://127.0.0.1:8000. In Prod z. B. https://api.example.com
# SCHNAPPSTER_API_BASE_URL=http://127.0.0.1:8000
#
# MCP_RESOURCE_SERVER_URL — unter welcher URL Clients DIESEN MCP-Server erreichen
#   (OAuth-Metadaten, Host-/Origin-Pruefung), inkl. Pfad z. B. …/mcp.
#   Default: http://127.0.0.1:8766/mcp. Nach eigenem Tunnel/ngrok setzen.
#   Bei ``uv run mcp-server --tunnel`` nicht noetig (wird automatisch gesetzt).
# MCP_RESOURCE_SERVER_URL=https://example.trycloudflare.com/mcp

# ------------------------------------------------------------
# Frontend: Next.js / Vercel
# ------------------------------------------------------------
# Fuer lokales Next.js koennen diese Werte direkt aus derselben Root-.env gelesen werden.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=