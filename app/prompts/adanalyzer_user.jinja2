Titel: {{ title }}
Preis: {{ price_display }}

{% if description %}
    Beschreibung: {{ description }}
{% endif %}

{% if condition %}
    Zustand: {{ condition }}
{% endif %}

{% if shipping_cost %}
    Versand: {{ shipping_cost }}
{% endif %}

{% if location %}
    Standort: {{ location }}
{% endif %}

{% if seller_name %}
    Verkäufer:
    - {{ seller_name }}

    {% if seller_type %}
        - Typ: {{ seller_type }}
    {% endif %}

    {% if seller_rating is not none %}
        {% if seller_rating == 2 %}
            - Bewertung: TOP
        {% elif seller_rating == 1 %}
            - Bewertung: OK
        {% elif seller_rating == 0 %}
            - Bewertung: Na ja
        {% else %}
            - Bewertung: Unbekannt
        {% endif %}
    {% endif %}

    {% if seller_friendly %}
        - Freundlich
    {% endif %}

    {% if seller_reliable %}
        - Zuverlässig
    {% endif %}

    {% if seller_active_since %}
        - Aktiv seit: {{ seller_active_since }}
    {% endif %}

{% endif %}

{% if comparison %}
    Vergleichsangebote aus derselben Suche ({{ comparison.count }} Angebote):
    {% for e in comparison.entries %}
    - {{ e.title }} ({{ e.price | int }}€){% if e.condition %} – {{ e.condition }}{% endif %}
    {% endfor %}
    Durchschnitt: {{ comparison.average }}€, Median: {{ comparison.median }}€
{% endif %}

{% if user_instructions %}
    [Zusätzliche Bewertungshinweise]
    {{ user_instructions }}
    [Ende der Bewertungshinweise]
{% endif %}
