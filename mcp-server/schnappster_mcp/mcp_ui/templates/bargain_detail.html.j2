<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Schnäppchen</title>
  <style>
    :root {
      color-scheme: light dark;
      font-family: system-ui, sans-serif;
      line-height: 1.45;
    }
    body {
      margin: 0;
      padding: 12px;
      background: transparent;
    }
    #root { max-width: 46rem; margin: 0 auto; }
    h1 { font-size: 1.2rem; margin: 0; font-weight: 700; }
    .muted { opacity: 0.75; font-size: 0.85rem; }
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 12px;
      padding: 12px;
      border-radius: 14px;
      background: linear-gradient(
        135deg,
        color-mix(in oklab, CanvasText 10%, Canvas),
        color-mix(in oklab, CanvasText 4%, Canvas)
      );
      border: 1px solid color-mix(in oklab, CanvasText 12%, Canvas);
      box-shadow: 0 8px 20px color-mix(in oklab, CanvasText 10%, transparent);
    }
    .hero-image-wrap {
      border-radius: 10px;
      overflow: hidden;
      background: color-mix(in oklab, CanvasText 5%, Canvas);
      border: 1px solid color-mix(in oklab, CanvasText 10%, Canvas);
      max-height: 18rem;
    }
    .hero-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 3px 9px;
      font-size: 0.82rem;
      border: 1px solid color-mix(in oklab, CanvasText 14%, Canvas);
      background: color-mix(in oklab, CanvasText 7%, Canvas);
    }
    {% include '_score.css.j2' %}
    .section { margin-top: 14px; }
    .section h2 {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin: 0 0 6px;
      opacity: 0.7;
    }
    .box {
      padding: 10px 12px;
      border-radius: 10px;
      background: color-mix(in oklab, CanvasText 6%, Canvas);
    }
    .expandable-text {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .expand-toggle {
      margin-top: 8px;
      border: 1px solid color-mix(in oklab, CanvasText 20%, Canvas);
      background: color-mix(in oklab, CanvasText 4%, Canvas);
      color: inherit;
      border-radius: 8px;
      padding: 4px 8px;
      cursor: pointer;
      font: inherit;
      font-size: 0.86rem;
    }
    .expand-toggle:hover {
      background: color-mix(in oklab, CanvasText 9%, Canvas);
    }
    a.link { color: inherit; word-break: break-all; }
    .empty { opacity: 0.7; font-size: 0.9rem; }
  </style>
</head>
<body>
  <div id="root">
    <p class="empty">Verbinde mit MCP-App…</p>
  </div>
  <script type="module">
    import { App } from "{{ ext_apps_import_url }}";

    const root = document.getElementById("root");

    {% include '_helpers.js.j2' %}

    function render(data) {
      root.innerHTML = "";
      if (!data || typeof data !== "object") {
        root.appendChild(el("p", { className: "empty" }, [text("Keine Daten.")]));
        return;
      }

      const title = data.title || "Anzeige";
      const score =
        data.bargain_score != null ? String(data.bargain_score) : "—";
      const imageUrl = resolvePrimaryImage(data);

      const locationText = [data.postal_code, data.city].filter(Boolean).join(" ");
      const offerBits = [
        data.price != null ? "Preis: " + fmtPrice(data.price) : null,
        data.seller_name ? "Verkäufer: " + data.seller_name : null,
        data.seller_type ? "Typ: " + data.seller_type : null,
      ].filter(Boolean);

      const heroChildren = [];
      if (imageUrl) {
        heroChildren.push(
          el("div", { className: "hero-image-wrap" }, [
            el("img", {
              className: "hero-image",
              src: imageUrl,
              alt: title,
              loading: "lazy",
              referrerPolicy: "no-referrer",
            }),
          ])
        );
      }
      heroChildren.push(
        el("div", null, [
          el("h2", null, [text("Angebot")]),
          el("h1", null, [text(title)]),
          el("div", { className: "hero-meta" }, [
            el("span", { className: "score " + scoreClass(data.bargain_score) }, [
              text("Score: " + score),
            ]),
            ...(locationText ? [el("span", { className: "chip" }, [text(locationText)])] : []),
            ...offerBits.map((entry) => el("span", { className: "chip" }, [text(entry)])),
          ]),
        ])
      );
      root.appendChild(el("div", { className: "hero" }, heroChildren));

      if (data.url) {
        const ka = el(
          "a",
          {
            className: "link",
            href: data.url,
            target: "_blank",
            rel: "noopener noreferrer",
          },
          [text("Auf Kleinanzeigen öffnen")]
        );
        ka.addEventListener("click", (ev) => {
          if (typeof app.openLink === "function") {
            ev.preventDefault();
            void app.openLink({ url: data.url });
          }
        });
        root.appendChild(el("p", { className: "section" }, [ka]));
      }

      const addSection = (label, bodyText) => {
        if (!bodyText) return;
        root.appendChild(
          el("div", { className: "section" }, [
            el("h2", null, [text(label)]),
            el("div", { className: "box" }, [text(bodyText)]),
          ])
        );
      };

      const addExpandableSection = (label, bodyText, previewLength = 260) => {
        if (!bodyText) return;
        const normalizedText = String(bodyText).trim();
        if (!normalizedText) return;
        if (normalizedText.length <= previewLength) {
          addSection(label, normalizedText);
          return;
        }
        const preview = normalizedText.slice(0, previewLength).trimEnd() + " …";
        const collapsedText = el("p", { className: "expandable-text" }, [text(preview)]);
        const fullText = el(
          "p",
          { className: "expandable-text", hidden: true },
          [text(normalizedText)]
        );
        const toggle = el("button", { className: "expand-toggle", type: "button" }, [
          text("Mehr anzeigen"),
        ]);
        toggle.addEventListener("click", () => {
          const expanded = !fullText.hidden;
          fullText.hidden = expanded;
          collapsedText.hidden = !expanded;
          toggle.textContent = expanded ? "Mehr anzeigen" : "Weniger anzeigen";
        });
        root.appendChild(
          el("div", { className: "section" }, [
            el("h2", null, [text(label)]),
            el("div", { className: "box" }, [collapsedText, fullText, toggle]),
          ])
        );
      };

      addSection("Kurzfassung", data.ai_summary);
      addExpandableSection("Begründung", data.ai_reasoning);

      if (data.description) {
        addExpandableSection("Beschreibung", data.description);
      }
    }

    function resolvePrimaryImage(data) {
      if (!data || typeof data !== "object") return null;
      if (typeof data.image_url === "string" && data.image_url.trim() !== "") {
        return data.image_url.trim();
      }
      if (Array.isArray(data.image_urls)) {
        const first = data.image_urls.find(
          (entry) => typeof entry === "string" && entry.trim() !== ""
        );
        return first ? String(first).trim() : null;
      }
      if (typeof data.image_urls === "string") {
        const first = data.image_urls
          .split(",")
          .map((entry) => entry.trim())
          .find((entry) => entry !== "");
        return first || null;
      }
      return null;
    }

    function renderStatus(message) {
      root.innerHTML = "";
      root.appendChild(el("p", { className: "empty" }, [text(message)]));
    }

    function renderError(message) {
      root.innerHTML = "";
      root.appendChild(el("h1", null, [text("Fehler")]));
      root.appendChild(
        el("div", { className: "box section" }, [text(message || "Unbekannter Fehler.")])
      );
    }

    function parseMaybeJson(value) {
      if (typeof value !== "string") return value;
      const trimmed = value.trim();
      if (!trimmed) return value;
      if (!trimmed.startsWith("{") && !trimmed.startsWith("[")) return value;
      try {
        return JSON.parse(trimmed);
      } catch (_e) {
        return value;
      }
    }

    function normalizeDetailPayload(raw) {
      let current = parseMaybeJson(raw);
      let guard = 0;
      while (guard < 8 && current != null) {
        guard += 1;
        if (Array.isArray(current)) {
          if (current.length === 0) return null;
          current = parseMaybeJson(current[0]);
          continue;
        }
        if (typeof current !== "object") return null;

        const candidateKeys = ["item", "ad", "data", "payload", "result", "text"];
        let extracted = false;
        for (const key of candidateKeys) {
          if (key in current) {
            current = parseMaybeJson(current[key]);
            extracted = true;
            break;
          }
        }
        if (extracted) continue;

        if ("content" in current && Array.isArray(current.content) && current.content.length > 0) {
          const textBlock = current.content.find((entry) => entry && entry.type === "text");
          current = parseMaybeJson(textBlock?.text ?? current.content[0]);
          continue;
        }

        if ("title" in current || "url" in current || "bargain_score" in current) {
          return current;
        }

        return current;
      }
      return null;
    }

    function parseToolDetailPayload(content) {
      const block = content?.find((c) => c.type === "text");
      if (!block?.text) throw new Error("Keine Textdaten im Tool-Ergebnis.");
      const normalized = normalizeDetailPayload(block.text);
      if (!normalized || typeof normalized !== "object") {
        throw new Error("Detaildaten konnten nicht extrahiert werden.");
      }
      return normalized;
    }

    const app = new App({ name: "Schnappster Schnäppchen", version: "1.0.0" });

    app.ontoolresult = ({ content }) => {
      try {
        render(parseToolDetailPayload(content));
      } catch (e) {
        renderError("JSON konnte nicht gelesen werden: " + stringifyError(e));
      }
    };

    try {
      renderStatus("Lade Anzeige…");
      await app.connect();
    } catch (e) {
      renderError("Verbindung fehlgeschlagen: " + stringifyError(e));
    }
  </script>
</body>
</html>
